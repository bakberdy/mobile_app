require "fileutils"

default_platform(:ios)

def project_root
  File.expand_path("../..", __dir__)
end

def write_export_options_plist(project_root)
  out = File.join(project_root, "build", "ios", "flutter_export_options.plist")
  FileUtils.mkdir_p(File.dirname(out))
  profile_name = ENV["IOS_PROVISIONING_PROFILE_NAME"]
  if profile_name.to_s.empty?
    File.write(out, File.read(File.join(__dir__, "ExportOptions.plist")))
  else
    File.write(
      out,
      <<~XML
        <?xml version="1.0" encoding="UTF-8"?>
        <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
        <plist version="1.0">
        <dict>
          <key>method</key>
          <string>app-store</string>
          <key>uploadBitcode</key>
          <false/>
          <key>uploadSymbols</key>
          <true/>
          <key>signingStyle</key>
          <string>manual</string>
          <key>provisioningProfiles</key>
          <dict>
            <key>com.bakberdi.mobile-app</key>
            <string>#{profile_name}</string>
          </dict>
        </dict>
        </plist>
      XML
    )
  end
  "build/ios/flutter_export_options.plist"
end

def setup_ci_signing
  return unless ENV["CI"]

  cert_path = ENV["IOS_BUILD_CERTIFICATE_PATH"]
  profile_path = ENV["IOS_BUILD_PROVISION_PROFILE_PATH"]
  return if cert_path.to_s.empty? || profile_path.to_s.empty?

  keychain_password = ENV.fetch("IOS_KEYCHAIN_PASSWORD", "build_keychain_temp")
  create_keychain(
    name: "build.keychain",
    password: keychain_password,
    default_keychain: true,
    unlock: true,
    timeout: 3600,
    lock_when_sleeps: false
  )
  import_certificate(
    certificate_path: cert_path,
    certificate_password: ENV.fetch("IOS_BUILD_CERTIFICATE_PASSWORD"),
    keychain_name: "build.keychain",
    keychain_password: keychain_password
  )
  install_provisioning_profile(path: profile_path)
end

def asc_api_key
  key_path = ENV["ASC_KEY_PATH"]
  UI.user_error!("ASC_KEY_PATH must point to the App Store Connect API .p8 file") if key_path.to_s.empty? || !File.file?(key_path)

  app_store_connect_api_key(
    key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
    issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
    key_filepath: key_path,
    duration: 1200,
    in_house: false
  )
end

platform :ios do
  desc "Build production IPA with Flutter and upload to TestFlight"
  lane :beta_production do
    setup_ci_signing
    asc_api_key

    if ENV["CI"] && ENV["IOS_PROVISIONING_PROFILE_NAME"].to_s.empty?
      UI.user_error!("IOS_PROVISIONING_PROFILE_NAME is required in CI (exact profile name from Apple Developer for com.bakberdi.mobile-app)")
    end

    api_url = ENV.fetch("PRODUCTION_API_URL")
    environment = ENV.fetch("PRODUCTION_ENVIRONMENT")
    export_plist = write_export_options_plist(project_root)

    Dir.chdir(project_root) do
      sh(
        "flutter", "build", "ipa",
        "--flavor", "production",
        "--release",
        "--dart-define=API_URL=#{api_url}",
        "--dart-define=ENVIRONMENT=#{environment}",
        "--export-options-plist=#{export_plist}"
      )
    end

    ipa = Dir.glob(File.join(project_root, "build/ios/ipa/*.ipa")).first
    UI.user_error!("IPA not found under build/ios/ipa") if ipa.nil?

    upload_to_testflight(
      ipa: ipa,
      skip_waiting_for_build_processing: true,
      api_key: lane_context[SharedValues::APP_STORE_CONNECT_API_KEY]
    )
  end
end
