# Local Fastlane env for Android. Copy to keys/.env (gitignored). Paths are relative
# to android/ unless absolute.

# Google Play API service account JSON (see .github/docs/android.md → Step B2).
# CI uses PLAY_STORE_SERVICE_ACCOUNT_JSON (full JSON as secret) instead.
PLAY_STORE_SERVICE_ACCOUNT_JSON_PATH=keys/play-service-account.json

# --- Google Play: where the build goes (track) ---

# Which Play track receives this upload. Default in Fastlane: internal
#
#   internal    — Internal testing
#   alpha       — Closed testing (alpha)
#   beta        — Open testing (beta)
#   production  — Production (live users)
#
PLAY_TRACK=internal

# --- Google Play: release “status” in the API (not the same as track) ---

# How the new release is created in Google Play. Default in Fastlane: draft
#
#   draft       — Save as a draft; you finish review / rollout in Play Console. Required
#                 while the app listing is still a “draft” app in Play.
#   completed   — Mark the release as completed in one step (roll out per track rules).
#                 Use only when the app is no longer draft-only; otherwise the API
#                 returns: “Only releases with status draft may be created on draft app.”
#   inProgress  — Staged rollout in progress (when applicable).
#   halted      — Halted rollout.
#
PLAY_RELEASE_STATUS=draft

# Per-flavor signing: android/key.<flavor>.properties (see android/key.properties.example
# and .github/docs/android.md → Step A2). Not loaded from this file.
